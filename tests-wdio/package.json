{
  "name": "prolific-pulse-tests",
  "private": true,
  "type": "module",
  "devDependencies": {
    "@wdio/cli": "^9",
    "@wdio/local-runner": "^9",
    "@wdio/mocha-framework": "^9",
    "@wdio/spec-reporter": "^9",
    "archiver": "^7",
    "webdriverio": "^9"
  },
  "scripts": {
    "test": "wdio run wdio.conf.js",
    "test:fast": "SKIP_SLOW=1 wdio run wdio.conf.js",
    "test:chrome": "wdio run wdio.chrome.conf.js",
    "test:chrome:fast": "SKIP_SLOW=1 wdio run wdio.chrome.conf.js",
    "test:all": "HEADLESS=1 wdio run wdio.conf.js && HEADLESS=1 wdio run wdio.chrome.conf.js",
    "test:all:fast": "SKIP_SLOW=1 HEADLESS=1 wdio run wdio.conf.js && SKIP_SLOW=1 HEADLESS=1 wdio run wdio.chrome.conf.js",
    "setup-login": "node setup-login.js",
    "setup-login:chrome": ".venv/bin/python setup-login-chrome.py"
  }
}
