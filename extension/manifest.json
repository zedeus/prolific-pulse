{
  "manifest_version": 3,
  "name": "Prolific Pulse",
  "version": "1.1.0",
  "description": "Real-time study monitoring for Prolific. Get instant alerts when studies matching your criteria become available.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "scripting",
    "tabs",
    "alarms",
    "storage",
    "webRequest",
    "webRequestBlocking",
    "webRequestFilterResponse"
  ],
  "host_permissions": [
    "*://*.prolific.com/*",
    "http://localhost:8080/*",
    "ws://localhost:8080/*",
    "http://127.0.0.1:8080/*",
    "ws://127.0.0.1:8080/*",
    "https://localhost:8080/*",
    "wss://localhost:8080/*",
    "https://127.0.0.1:8080/*",
    "wss://127.0.0.1:8080/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://*.prolific.com http://localhost:8080 ws://localhost:8080 http://127.0.0.1:8080 ws://127.0.0.1:8080 https://localhost:8080 wss://localhost:8080 https://127.0.0.1:8080 wss://127.0.0.1:8080;"
  },
  "background": {
    "scripts": [
      "background/domain.js",
      "background/settings.js",
      "background/state.js",
      "background/actions.js",
      "background/adapters.js",
      "background.js"
    ]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "prolific-pulse@prolific-pulse",
      "strict_min_version": "110.0"
    }
  },
  "homepage_url": "https://github.com/zedeus/prolific-pulse",
  "action": {
    "default_title": "Prolific Pulse",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  }
}
